# Configuration de déploiement STAGING
# Copiez ce fichier en .env.staging et remplissez vos valeurs

# Informations du serveur de staging
REMOTE_HOST=staging.votre-serveur.com
REMOTE_USER=votre-utilisateur
REMOTE_PATH=/var/www/html/wp-content/plugins

# Optionnel : Port SSH personnalisé
# SSH_PORT=22

# Optionnel : Clé SSH spécifique
# SSH_KEY_PATH=~/.ssh/id_rsa
