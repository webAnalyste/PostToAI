# Configuration de déploiement PRODUCTION
# Copiez ce fichier en .env.production et remplissez vos valeurs

# Informations du serveur distant
REMOTE_HOST=votre-serveur.com
REMOTE_USER=votre-utilisateur
REMOTE_PATH=/var/www/html/wp-content/plugins

# Optionnel : Port SSH personnalisé
# SSH_PORT=22

# Optionnel : Clé SSH spécifique
# SSH_KEY_PATH=~/.ssh/id_rsa
